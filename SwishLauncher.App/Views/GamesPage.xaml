<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwishLauncher.App.Views.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SwishLauncher.Core.Models"
    xmlns:controls="using:SwishLauncher.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="0,32,0,0">

        <!-- Title row -->
        <!-- Replace the existing title row StackPanel -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16"
            Padding="48,0" VerticalAlignment="Center">
            <TextBlock
        Text="{x:Bind ViewModel.Title, Mode=OneWay}"
        Style="{ThemeResource TitleTextBlockStyle}"/>
            <ProgressRing
        IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
        Width="20" Height="20" VerticalAlignment="Center"/>
            <Button
    Command="{x:Bind ViewModel.ScanCommand}"
    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay,
        Converter={StaticResource BoolNegationConverter}}"
    ToolTipService.ToolTip="Scan for installed games"
    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Scan"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- CoverFlow carousel -->
        <controls:CoverFlowControl
            x:Name="GamesCoverFlow"
            Grid.Row="1"
            VerticalAlignment="Stretch"
            MinHeight="400"
            ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
            SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}"
            ItemActivated="GamesCoverFlow_ItemActivated">

            <controls:CoverFlowControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="220" Height="300" CornerRadius="12" CacheMode="BitmapCache">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <Grid>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12"/>
                            <Border CornerRadius="12" Width="220" Height="300">
                                <Image Source="{Binding CoverArtPath,
        Converter={StaticResource PathToImageSourceConverter}}"
        Stretch="UniformToFill"/>
                            </Border>
                            <FontIcon
                    Glyph="&#xE7FC;"
                    FontSize="60"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.25"
                    Visibility="{Binding CoverArtPath,
                        Converter={StaticResource NullToVisibleConverter}}"/>
                            <Border VerticalAlignment="Bottom" CornerRadius="0,0,12,12" Padding="12,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock
                        Text="{Binding Title}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"
                        Foreground="White"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </controls:CoverFlowControl.ItemTemplate>
        </controls:CoverFlowControl>

        <!-- Empty state -->
        <TextBlock
            Grid.Row="1"
            Text="No games found. Add some!"
            Style="{ThemeResource BodyTextBlockStyle}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.5"
            Visibility="{x:Bind ViewModel.Games.Count, Mode=OneWay,
                Converter={StaticResource ZeroToVisibleConverter}}"/>

    </Grid>
</Page>
