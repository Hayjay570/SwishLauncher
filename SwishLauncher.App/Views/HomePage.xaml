<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwishLauncher.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <!-- Loading overlay -->
        <ProgressRing
            IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
            Width="40" Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                Converter={StaticResource BoolToVisibilityConverter}}"/>

        <ScrollViewer
            VerticalScrollBarVisibility="Hidden"
            HorizontalScrollBarVisibility="Disabled"
            Padding="0,0,0,32"
            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                Converter={StaticResource BoolNegationToVisibilityConverter}}">

            <StackPanel Spacing="0">

                <!-- HERO BANNER: collapsed until data arrives, fades in from code-behind -->
                <Grid
                    x:Name="HeroBanner"
                    Height="420"
                    Visibility="Collapsed"
                    Opacity="0">

                    <Image
                        x:Name="HeroImage"
                        Stretch="UniformToFill"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                    <!-- Cinematic vignette -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#BB000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="0.3"/>
                                <GradientStop Color="#00000000" Offset="0.5"/>
                                <GradientStop Color="#EE000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Content overlay -->
                    <StackPanel
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Left"
                        Margin="48,0,0,44"
                        Spacing="12"
                        MaxWidth="560">

                        <TextBlock
                            x:Name="HeroSourceBadge"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            CharacterSpacing="150"
                            Foreground="#99FFFFFF"/>

                        <TextBlock
                            x:Name="HeroTitle"
                            Style="{ThemeResource DisplayTextBlockStyle}"
                            Foreground="White"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2"
                            TextWrapping="Wrap"
                            FontSize="40"/>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                            <Button
                                x:Name="HeroPlayButton"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="HeroPlayButton_Click"
                                Padding="24,10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE102;" FontSize="16"/>
                                    <TextBlock Text="Play"/>
                                </StackPanel>
                            </Button>
                            <Button
                                x:Name="HeroDetailsButton"
                                Background="Transparent"
                                BorderBrush="#66FFFFFF"
                                Foreground="White"
                                Click="HeroDetailsButton_Click"
                                Padding="20,10">
                                <TextBlock Text="More Info"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <Grid.Resources>
                        <Storyboard x:Key="HeroEntranceSb">
                            <DoubleAnimation
                                Storyboard.TargetName="HeroBanner"
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1"
                                Duration="0:0:0.5">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </Grid.Resources>
                </Grid>

                <!-- SECTION: Featured -->
                <StackPanel
                    x:Name="FeaturedSection"
                    Spacing="16"
                    Padding="48,36,48,0"
                    Visibility="{x:Bind ViewModel.FeaturedGames.Count, Mode=OneWay,
                        Converter={StaticResource NonZeroToVisibilityConverter}}">

                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="30"/>
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <TextBlock
                        Text="FEATURED"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Opacity="0.6"
                        CharacterSpacing="150"/>

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollMode="Disabled">
                        <ItemsRepeater
                            x:Name="FeaturedRepeater"
                            ItemsSource="{x:Bind ViewModel.FeaturedGames, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="16"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="200" Height="280"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Click="GameCard_Click">
                                        <Border CornerRadius="12" Width="200" Height="280">
                                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                                            <Grid>
                                                <Border
                                                    CornerRadius="12"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                                                <Image
                                                    Source="{Binding CoverArtPath,
                                                        Converter={StaticResource PathToImageSourceConverter}}"
                                                    Stretch="UniformToFill"/>
                                                <Border
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,12,12"
                                                    Padding="12,10">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="Transparent" Offset="0"/>
                                                            <GradientStop Color="#EE000000"   Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock
                                                        Text="{Binding Title}"
                                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                        Foreground="White"
                                                        TextTrimming="CharacterEllipsis"
                                                        MaxLines="2"
                                                        TextWrapping="Wrap"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- SECTION: Recently Played -->
                <StackPanel
                    x:Name="RecentSection"
                    Spacing="16"
                    Padding="48,36,48,0"
                    Visibility="{x:Bind ViewModel.RecentlyPlayed.Count, Mode=OneWay,
                        Converter={StaticResource NonZeroToVisibilityConverter}}">

                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="30"/>
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <TextBlock
                        Text="RECENTLY PLAYED"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Opacity="0.6"
                        CharacterSpacing="150"/>

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollMode="Disabled">
                        <ItemsRepeater
                            x:Name="RecentRepeater"
                            ItemsSource="{x:Bind ViewModel.RecentlyPlayed, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="160" Height="220"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Click="GameCard_Click">
                                        <Border CornerRadius="10" Width="160" Height="220">
                                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                                            <Grid>
                                                <Border
                                                    CornerRadius="10"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                                                <Image
                                                    Source="{Binding CoverArtPath,
                                                        Converter={StaticResource PathToImageSourceConverter}}"
                                                    Stretch="UniformToFill"/>
                                                <Border
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,10,10"
                                                    Padding="10,8">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="Transparent" Offset="0"/>
                                                            <GradientStop Color="#DD000000"   Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock
                                                        Text="{Binding Title}"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Foreground="White"
                                                        TextTrimming="CharacterEllipsis"
                                                        MaxLines="1"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- SECTION: Favourites -->
                <StackPanel
                    x:Name="FavouritesSection"
                    Spacing="16"
                    Padding="48,36,48,0"
                    Visibility="{x:Bind ViewModel.Favourites.Count, Mode=OneWay,
                        Converter={StaticResource NonZeroToVisibilityConverter}}">

                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="30"/>
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <TextBlock
                        Text="FAVOURITES"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Opacity="0.6"
                        CharacterSpacing="150"/>

                    <ItemsRepeater
                        x:Name="FavouritesRepeater"
                        ItemsSource="{x:Bind ViewModel.Favourites, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinItemWidth="140"
                                MinItemHeight="196"
                                MinColumnSpacing="12"
                                MinRowSpacing="12"
                                ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    HorizontalAlignment="Stretch"
                                    Click="GameCard_Click">
                                    <Border CornerRadius="8" Height="196">
                                        <Border.Shadow><ThemeShadow/></Border.Shadow>
                                        <Grid>
                                            <Border
                                                CornerRadius="8"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                                            <Image
                                                Source="{Binding CoverArtPath,
                                                    Converter={StaticResource PathToImageSourceConverter}}"
                                                Stretch="UniformToFill"/>
                                            <Border
                                                VerticalAlignment="Bottom"
                                                CornerRadius="0,0,8,8"
                                                Padding="8,6">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                        <GradientStop Color="#CC000000"   Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock
                                                    Text="{Binding Title}"
                                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                                    Foreground="White"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxLines="1"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel
                    x:Name="EmptyState"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="0,120,0,0">
                    <FontIcon Glyph="&#xE80F;" FontSize="48" Opacity="0.3"
                              HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Your library is empty"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Opacity="0.5"/>
                    <TextBlock
                        Text="Head to the Games tab and hit Scan to get started."
                        Style="{ThemeResource BodyTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Opacity="0.4"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
