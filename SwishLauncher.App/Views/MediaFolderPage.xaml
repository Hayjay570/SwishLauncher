<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwishLauncher.App.Views.MediaFolderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SwishLauncher.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="0,32,0,0">

        <!-- Title row — folder name + back button -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12"
                    Padding="48,0" VerticalAlignment="Center">
            <Button
                x:Name="BackButton"
                Background="Transparent"
                BorderBrush="Transparent"
                Padding="8"
                VerticalAlignment="Center"
                Click="BackButton_Click">
                <FontIcon Glyph="&#xE76B;" FontSize="18"/>
            </Button>
            <TextBlock
                x:Name="FolderTitleBlock"
                Style="{ThemeResource TitleTextBlockStyle}"
                VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Folder contents CoverFlow — sub-folders and/or media items -->
        <controls:CoverFlowControl
            x:Name="FolderCoverFlow"
            Grid.Row="1"
            VerticalAlignment="Stretch"
            MinHeight="400"
            ItemActivated="FolderCoverFlow_ItemActivated">

            <controls:CoverFlowControl.ItemTemplate>
                <!--
                    No x:DataType — CoverFlowControl is a non-ItemsControl.
                    DataContext is MediaBrowserItem. Same mixed template as MediaPage.
                -->
                <DataTemplate>
                    <Grid Width="220" Height="300">

                        <!-- FOLDER CARD -->
                        <Border
                            CornerRadius="12"
                            CacheMode="BitmapCache"
                            Visibility="{Binding IsFolder,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid>
                                <Border
                                    CornerRadius="12"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                                <FontIcon
                                    Glyph="&#xED43;"
                                    FontSize="110"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Margin="0,0,0,40"/>
                                <Border
                                    VerticalAlignment="Bottom"
                                    CornerRadius="0,0,12,12"
                                    Padding="12,10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#DD000000"   Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock
                                        Text="{Binding Label}"
                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="2"
                                        TextWrapping="Wrap"
                                        Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- MEDIA ITEM CARD -->
                        <Border
                            CornerRadius="12"
                            CacheMode="BitmapCache"
                            Visibility="{Binding IsFolder,
                                Converter={StaticResource BoolNegationToVisibilityConverter}}">
                            <Border.Shadow><ThemeShadow/></Border.Shadow>
                            <Grid>
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="12"/>
                                <Border Width="220" Height="300" CornerRadius="12">
                                    <Image
                                        Source="{Binding Entry.ThumbnailPath,
                                            Converter={StaticResource PathToImageSourceConverter}}"
                                        Stretch="UniformToFill"/>
                                </Border>
                                <FontIcon
                                    Glyph="&#xE8B2;"
                                    FontSize="60"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Opacity="0.25"/>
                                <Border
                                    VerticalAlignment="Bottom"
                                    CornerRadius="0,0,12,12"
                                    Padding="12,8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#CC000000"   Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock
                                        Text="{Binding Label}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1"
                                        Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>

                    </Grid>
                </DataTemplate>
            </controls:CoverFlowControl.ItemTemplate>

        </controls:CoverFlowControl>

    </Grid>
</Page>
