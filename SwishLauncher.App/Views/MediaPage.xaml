<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwishLauncher.App.Views.MediaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SwishLauncher.Core.Models"
    xmlns:controls="using:SwishLauncher.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="0,32,0,0">

        <!-- Title row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16"
                    Padding="48,0" VerticalAlignment="Center">
            <TextBlock
                Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                Style="{ThemeResource TitleTextBlockStyle}"/>
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                Width="20" Height="20" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- CoverFlow carousel -->
        <controls:CoverFlowControl
            x:Name="MediaCoverFlow"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.MediaItems, Mode=OneWay}"
            SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}"
            ItemActivated="MediaCoverFlow_ItemActivated">

            <controls:CoverFlowControl.ItemTemplate>
                <DataTemplate x:DataType="models:MediaEntry">
                    <Border
                        Width="220" Height="300"
                        CornerRadius="12"
                        CacheMode="BitmapCache">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>

                        <Grid>
                            <!-- Background fill -->
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="12"/>
                            <!-- Thumbnail -->
                            <Image Source="{x:Bind ThumbnailPath}" Stretch="UniformToFill"/>
                            <!-- Placeholder icon -->
                            <FontIcon
                                Glyph="&#xE8B2;"
                                FontSize="60"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.25"/>
                            <!-- Title gradient overlay -->
                            <Border
                                VerticalAlignment="Bottom"
                                CornerRadius="0,0,12,12"
                                Padding="12,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC000000"   Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock
                                    Text="{x:Bind Title}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"
                                    Foreground="White"/>
                            </Border>
                        </Grid>

                    </Border>
                </DataTemplate>
            </controls:CoverFlowControl.ItemTemplate>

        </controls:CoverFlowControl>

        <!-- Empty state -->
        <TextBlock
            Grid.Row="1"
            Text="No media found. Add some!"
            Style="{ThemeResource BodyTextBlockStyle}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.5"
            Visibility="{x:Bind ViewModel.MediaItems.Count, Mode=OneWay,
                Converter={StaticResource ZeroToVisibleConverter}}"/>

    </Grid>
</Page>
