<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwishLauncher.App.Views.GameDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        AcrylicBrush in WinUI 3 / WindowsAppSDK 1.x does not expose BackgroundSource.
        It always composites against the window backdrop (Mica) automatically.
    -->
    <Page.Background>
        <AcrylicBrush
            TintColor="#0A0A0A"
            TintOpacity="0.55"
            FallbackColor="#1A1A1A"/>
    </Page.Background>

    <Grid ColumnDefinitions="*,*" Padding="48,36">

        <!-- ── LEFT: Cover art ─────────────────────────────────────────── -->
        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border
                Width="320" Height="420"
                CornerRadius="16"
                CacheMode="BitmapCache">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <Grid>
                    <Image
                        Source="{x:Bind ViewModel.CoverArtPath, Mode=OneWay}"
                        Stretch="UniformToFill"/>
                    <FontIcon
                        Glyph="&#xE7FC;"
                        FontSize="80"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.3"
                        Visibility="{x:Bind ViewModel.CoverArtPath,
                            Mode=OneWay,
                            Converter={StaticResource NullToVisibleConverter}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── RIGHT: Single acrylic island ───────────────────────────── -->
        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">

            <Border CornerRadius="16" Padding="32">
                <Border.Background>
                    <AcrylicBrush
                        TintColor="#141414"
                        TintOpacity="0.7"
                        FallbackColor="#242424"/>
                </Border.Background>
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>

                <StackPanel Spacing="20">

                    <!-- Title + Platform (platform uppercased in ViewModel) -->
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            TextWrapping="Wrap"
                            MaxLines="2"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.Platform, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6"
                            CharacterSpacing="80"/>
                    </StackPanel>

                    <!-- Rating -->
                    <RatingControl
                        Value="{x:Bind ViewModel.Rating, Mode=OneWay}"
                        IsReadOnly="True"
                        MaxRating="5"/>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.3"/>

                    <!-- Description -->
                    <TextBlock
                        Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        TextWrapping="Wrap"
                        MaxLines="6"
                        TextTrimming="CharacterEllipsis"
                        Opacity="0.85"
                        LineHeight="22"/>

                    <!-- Last played + playtime -->
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel Spacing="2">
                            <TextBlock Text="LAST PLAYED" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5" CharacterSpacing="60"/>
                            <TextBlock Text="{x:Bind ViewModel.LastPlayed, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="PLAYTIME" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5" CharacterSpacing="60"/>
                            <TextBlock Text="{x:Bind ViewModel.Playtime, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.3"/>

                    <!-- Action row: Play (dominant) + Favourite (compact, right) -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                        <Button
                            Grid.Column="0"
                            Content="▶  Play"
                            Command="{x:Bind ViewModel.LaunchCommand}"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                Converter={StaticResource BoolNegationConverter}}"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            FontSize="16"/>

                        <Button
                            Grid.Column="1"
                            Command="{x:Bind ViewModel.ToggleFavouriteCommand}"
                            Width="48" Height="48"
                            ToolTipService.ToolTip="Add to favourites"
                            Padding="0">
                            <FontIcon
                                Glyph="{x:Bind ViewModel.IsFavourite, Mode=OneWay,
                                    Converter={StaticResource FavouriteGlyphConverter}}"
                                FontSize="18"/>
                        </Button>

                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>
