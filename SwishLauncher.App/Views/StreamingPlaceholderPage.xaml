<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwishLauncher.App.Views.StreamingPlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SwishLauncher.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="0,32,0,0">

        <!-- ── Header row ─────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16"
                    Padding="48,0" VerticalAlignment="Center">

            <Button
                x:Name="BackButton"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Back_Click"
                ToolTipService.ToolTip="Back">
                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
            </Button>

            <TextBlock
                Text="Streaming Services"
                Style="{ThemeResource TitleTextBlockStyle}"/>
        </StackPanel>

        <!-- ── Service coverflow ──────────────────────────────────────────── -->
        <!--
            Card gradient colours come from StreamingServiceItem.Color1 / Color2
            which are Windows.UI.Color values — they bind fine to GradientStop.Color.
        -->
        <controls:CoverFlowControl
            x:Name="StreamingCoverFlow"
            Grid.Row="1"
            VerticalAlignment="Stretch"
            MinHeight="400"
            ItemsSource="{x:Bind EnabledServices, Mode=OneWay}"
            SelectedIndex="{x:Bind SelectedIndex, Mode=TwoWay}"
            ItemActivated="StreamingCoverFlow_ItemActivated">

            <controls:CoverFlowControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="220" Height="300" CornerRadius="12" CacheMode="BitmapCache">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <Grid>
                            <Border CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{Binding Color1}" Offset="0"/>
                                        <GradientStop Color="{Binding Color2}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <FontIcon
                                Glyph="{Binding Glyph}"
                                FontSize="72"
                                Foreground="#50FFFFFF"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,0,0,48"/>
                            <StackPanel
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Spacing="4"
                                Margin="0,0,0,32">
                                <TextBlock
                                    Text="{Binding Name}"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    HorizontalAlignment="Center"
                                    Foreground="White"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"/>
                                <TextBlock
                                    Text="Open in browser"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    HorizontalAlignment="Center"
                                    Foreground="#80FFFFFF"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </controls:CoverFlowControl.ItemTemplate>
        </controls:CoverFlowControl>

        <!-- ── Empty state ────────────────────────────────────────────────── -->
        <StackPanel
            Grid.Row="1"
            x:Name="EmptyPanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12">
            <FontIcon Glyph="&#xE8B2;" FontSize="56" Opacity="0.25" HorizontalAlignment="Center"/>
            <TextBlock
                Text="No streaming services enabled."
                Style="{ThemeResource BodyTextBlockStyle}"
                HorizontalAlignment="Center"
                Opacity="0.5"/>
            <TextBlock
                Text="Enable some in Settings."
                Style="{ThemeResource CaptionTextBlockStyle}"
                HorizontalAlignment="Center"
                Opacity="0.4"/>
        </StackPanel>

    </Grid>
</Page>
